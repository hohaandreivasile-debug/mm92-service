# Supabase Configuration (pentru mod online)
# Copiază acest fișier ca .env și completează cu valorile tale
# Dacă nu sunt completate, aplicația funcționează offline

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic AI (Claude — cel mai bun la structurare)
# Obțineți de la: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Google AI (Gemini Flash — cel mai ieftin, context mare)
# Obțineți de la: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your-gemini-key-here

# Notă: Dacă ambele sunt configurate, se folosește Gemini (mai ieftin).
# Dacă doar una e configurată, se folosește cea disponibilă.
